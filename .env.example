# ToolVerse Environment Variables Template

# Database Configuration
# MongoDB Atlas connection string for production
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/toolverse

# Authentication
# JWT secret for signing tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-random-jwt-secret-key-here

# Analytics
# Optional: Google Analytics or similar
NEXT_PUBLIC_ANALYTICS_ID=

# API Configuration
# Base URL for API calls
NEXT_PUBLIC_API_URL=http://localhost:3000

# Feature Flags
# Enable/disable features
NEXT_PUBLIC_ENABLE_AUTH=false
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SHARING=true

# Deployment
# Environment type: development, staging, production
NODE_ENV=development

# Optional: Email Configuration for notifications
EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_API_KEY=

# Optional: AI Provider Configuration
# For AI-powered tools
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: File Storage
# For image and file uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
